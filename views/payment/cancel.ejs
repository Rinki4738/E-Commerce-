<% layout('layouts/boilerplate') %>
<%- include('../partials/nav') %>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="fas fa-times-circle text-warning" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="card-title text-warning mb-3">Payment Cancelled</h2>
                    <p class="card-text mb-3">
                        Your payment has been cancelled. Your cart items are still saved and ready for checkout.
                    </p>

                    <div class="alert alert-info" role="alert">
                        <p>You can return to your cart and try the payment again whenever you're ready.</p>
                    </div>

                    <div class="mt-4">
                        <a href="/user/cart" class="btn btn-warning me-2">Return to Cart</a>
                        <a href="/" class="btn btn-outline-primary">Continue Shopping</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
